# MonitorMe local runtime
MONITORME_DB=data/events/monitorme.db
MONITORME_HOST=127.0.0.1
MONITORME_PORT=8088

# Node1 Logitech C922 local camera
MONITORME_CAMERA_ID=c922_node1_gate
MONITORME_CAMERA_DEVICE=/dev/video0
MONITORME_CAMERA_SOURCE_KIND=local_v4l2
MONITORME_CAMERA_WIDTH=1280
MONITORME_CAMERA_HEIGHT=720
MONITORME_CAMERA_FPS=30
MONITORME_CAMERA_FOURCC=MJPG
MONITORME_CAPTURE_DURATION_SEC=10
MONITORME_MOTION_THRESHOLD=1.5

# Text model metadata only for future LLM summaries.
# Raw frames/events are not externally uploaded.
MONITORME_TEXT_MODEL_ID=google/gemma-3-1b-it
MONITORME_LLM_PROVIDER=disabled
MONITORME_REQUIRE_EVIDENCE=1

# Optional Step 17C real YOLO ONNX detector.
# Keep disabled unless the real ONNX file is present on Node1.
MONITORME_DETECTOR_ENABLED=0
MONITORME_DETECTOR_MODEL_ID=yolo11n-coco-onnx
MONITORME_DETECTOR_MODEL_PATH=models/object_detection/yolo11n.onnx
MONITORME_DETECTOR_CONF_THRESHOLD=0.35
MONITORME_DETECTOR_IOU_THRESHOLD=0.45
MONITORME_DETECTOR_MAX_DETECTIONS=20
MONITORME_DETECTOR_INPUT_SIZE=640
